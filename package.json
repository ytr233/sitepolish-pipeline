{
    "name": "sitepolish-pipeline",
    "version": "1.0.0",
    "private": true,
    "description": "A guided front-end validation, remediation, and preview workflow.",
    "type": "module",
    "scripts": {
        "guide": "node src/cli.js guide",
        "import": "node src/cli.js import",
        "audit": "node src/cli.js audit",
        "review": "node src/cli.js review",
        "compare": "node src/cli.js compare",
        "finalize": "node src/cli.js finalize",
        "example": "node src/cli.js example",
        "check:engine": "eslint src config eslint.config.js",
        "check:example": "html-validate \"examples/lantern-grove-learning/finished/*.html\" && stylelint \"examples/lantern-grove-learning/finished/*.css\" && eslint \"examples/lantern-grove-learning/finished/*.js\" && prettier \"examples/lantern-grove-learning/finished/**/*.{html,css,js}\" --check",
        "quality": "npm run check:engine && npm run check:example"
    },
    "devDependencies": {
        "@eslint/js": "^9.32.0",
        "eslint": "^9.32.0",
        "globals": "^16.3.0",
        "html-validate": "^10.2.1",
        "prettier": "^3.6.2",
        "stylelint": "^16.23.0",
        "stylelint-config-standard": "^38.0.0"
    }
}
